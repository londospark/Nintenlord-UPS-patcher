[Desktop Entry]
Version=1.0
Type=Application
Name=Install Nintenlord UPS Patcher
Comment=Download and install Nintenlord UPS Patcher from GitHub
Exec=bash -c 'curl -sL https://raw.githubusercontent.com/londospark/Nintenlord-UPS-patcher/main/.github/installers/install-nups.sh | bash'
Icon=application-x-executable
