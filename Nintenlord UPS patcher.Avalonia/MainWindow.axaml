<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Nintenlord.UPSpatcher.AvaloniaApp.MainWindow"
        Width="900"
        Height="700"
        MinWidth="760"
        MinHeight="560"
        Title="Nintenlord UPS patcher (Linux-compatible)">
  <TabControl Margin="12">
    <TabItem Header="Patch File">
      <ScrollViewer>
        <StackPanel Spacing="10" Margin="8">
          <TextBlock Text="Target file" />
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox x:Name="PatchTargetFileTextBox" />
            <Button Grid.Column="1" Content="Browse" Click="BrowsePatchTargetFile_Click" />
          </Grid>

          <TextBlock Text="UPS patch file" />
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox x:Name="PatchFileTextBox" />
            <Button Grid.Column="1" Content="Browse" Click="BrowsePatchFile_Click" />
          </Grid>

          <TextBlock Text="Output ROM file" Margin="0,8,0,0" />
          <TextBlock Text="Leave blank to patch the target file in-place."
                     FontSize="11" Opacity="0.6" Margin="0,-6,0,0" />
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox x:Name="PatchOutputFileTextBox"
                     Watermark="(optional — leave blank to patch in-place)" />
            <Button Grid.Column="1" Content="Browse" Click="BrowsePatchOutputFile_Click" />
          </Grid>

          <TextBlock Text="Patch mismatch behavior" Margin="0,8,0,0" />
          <StackPanel Spacing="4">
            <RadioButton x:Name="OnMismatchCancelRadio" Content="Cancel if patch does not match (safe default)" IsChecked="True" GroupName="MismatchMode" />
            <RadioButton x:Name="OnMismatchAskRadio" Content="Ask before patching if mismatch" GroupName="MismatchMode" />
            <RadioButton x:Name="OnMismatchWarnRadio" Content="Warn and continue if mismatch" GroupName="MismatchMode" />
            <RadioButton x:Name="OnMismatchForceRadio" Content="Always patch without warning" GroupName="MismatchMode" />
          </StackPanel>

          <CheckBox x:Name="CreateBackupCheckBox" Content="Create .bak backup before patching in-place" IsChecked="True" Margin="0,4,0,0" />

          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
            <Button x:Name="ApplyPatchButton" Content="Apply Patch" Click="ApplyPatch_Click" />
            <Button x:Name="CancelPatchButton" Content="Cancel" Click="CancelPatch_Click" IsVisible="False" />
            <Button Content="Clear" Click="ClearPatchTab_Click" />
          </StackPanel>

          <StackPanel x:Name="PatchProgressPanel" IsVisible="False" Spacing="4" Margin="0,8,0,0">
            <ProgressBar x:Name="PatchProgressBar" Minimum="0" Maximum="100" Value="0" Height="18" />
            <TextBlock x:Name="PatchStatusText" Text="" FontSize="11" />
          </StackPanel>
        </StackPanel>
      </ScrollViewer>
    </TabItem>

    <TabItem Header="Create UPS">
      <ScrollViewer>
        <StackPanel Spacing="10" Margin="8">
          <TextBlock Text="Original file" />
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox x:Name="OriginalFileTextBox" />
            <Button Grid.Column="1" Content="Browse" Click="BrowseOriginalFile_Click" />
          </Grid>

          <TextBlock Text="Modified file" />
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox x:Name="ModifiedFileTextBox" />
            <Button Grid.Column="1" Content="Browse" Click="BrowseModifiedFile_Click" />
          </Grid>

          <TextBlock Text="Output UPS file" />
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox x:Name="OutputPatchFileTextBox" />
            <Button Grid.Column="1" Content="Browse" Click="BrowseOutputPatchFile_Click" />
          </Grid>

          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
            <Button x:Name="CreatePatchButton" Content="Create Patch" Click="CreatePatch_Click" />
            <Button x:Name="CancelCreateButton" Content="Cancel" Click="CancelCreate_Click" IsVisible="False" />
            <Button Content="Clear" Click="ClearCreateTab_Click" />
          </StackPanel>
          <StackPanel x:Name="CreateProgressPanel" IsVisible="False" Spacing="4" Margin="0,8,0,0">
            <ProgressBar x:Name="CreateProgressBar" Minimum="0" Maximum="100" Value="0" Height="18" />
            <TextBlock x:Name="CreateStatusText" Text="" FontSize="11" />
          </StackPanel>
        </StackPanel>
      </ScrollViewer>
    </TabItem>

    <TabItem Header="Inspect UPS">
      <ScrollViewer>
        <StackPanel Spacing="10" Margin="8">
          <TextBlock Text="UPS patch file" />
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox x:Name="InspectPatchFileTextBox" />
            <Button Grid.Column="1" Content="Browse" Click="BrowseInspectPatchFile_Click" />
          </Grid>

          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <Button Content="Read Patch Data" Click="ReadPatchData_Click" />
            <Button Content="Clear" Click="ClearInspectTab_Click" />
          </StackPanel>

          <TextBlock Text="Patch details" Margin="0,12,0,0" />
          <TextBox x:Name="InspectOutputTextBox"
                   AcceptsReturn="True"
                   IsReadOnly="True"
                   MinHeight="360"
                   FontFamily="Consolas,Courier New,monospace" />
        </StackPanel>
      </ScrollViewer>
    </TabItem>
  </TabControl>
</Window>


